{
  "manifest_version": 3,
  "name": "intapp-celeste-ext",
  "version": "0.1.0",
  "description": "Corporate tree viewer and entity selector for Intapp / Celeste",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://*/*"
  ],

  "action": {
    "default_popup": "corporate-tree.html",
    "default_title": "Corporate Tree"
  },

  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
