{
  "manifest_version": 3,
  "name": "PR_EXT_tree_compare",
  "version": "1.1.4",
  "description": "PR_EXT_tree_compare v1.1.4 — credential manager for Intapp extensions",

  "permissions": [
    "storage",
    "clipboardRead",
    "clipboardWrite"
  ],

  "host_permissions": [
    "https://*/*"
  ],

  "action": {
    "default_popup": "PR_EXT_tree_compare.html",
    "default_title": "PR_EXT_tree_compare"
  },

  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
